{{ ansible_managed | comment }}

# Get editor completions based on the config schema
"$schema" = 'https://starship.rs/config-schema.json'

format = """
$username\
$hostname\
$shlvl\
$directory\
$git_branch\
$git_commit\
$git_state\
$git_status\
$docker_context\
$package\
$nodejs\
$php\
$python\
$ruby\
$sudo\
$cmd_duration\
$line_break\
$status\
$container\
$shell\
$character"""

right_format = "{{ config_starship_right_format }}"
scan_timeout = {{ config_starship_scan_timeout }}
command_timeout = {{ config_starship_command_timeout }}
add_newline = {{ config_starship_add_newline }}

[character]
success_symbol = "[ÔØ»](bold green)"
error_symbol = "[ÔØ»](bold red)"

[cmd_duration]
style = "bold yellow"

[container]
